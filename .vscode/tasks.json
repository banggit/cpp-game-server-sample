{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "macos-debug"],
            "windows": {
                "args": ["--preset", "windows-debug"]
            },
            "linux": {
                "args": ["--preset", "linux-debug"]
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "cmake: build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "macos-debug"],
            "windows": {
                "args": ["--build", "--preset", "windows-debug"]
            },
            "linux": {
                "args": ["--build", "--preset", "linux-debug"]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "cmake: configure (Debug)",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        }
    ]
}